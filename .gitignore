# Dependencies
node_modules/

# Env files
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime / cache
.cache/
.tmp/
temp/
tmp/

# Prisma local database
prisma/dev.db
prisma/dev.db-journal
prisma/dev.db-wal
prisma/dev.db-shm
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm

# Keep Prisma migrations
!prisma/migrations/
!prisma/migrations/**

# Uploaded files from admin panel
site/uploads/
!site/uploads/.gitkeep
!site/uploads/products/
!site/uploads/products/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Build / coverage
coverage/
dist/
build/

# Local backups
*.backup
*.bak
*.tmp
